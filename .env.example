# ── Rogan Live · Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in the values.
# NEVER commit your real .env file to version control.

# Database
DATABASE_URL=file:./dev.db

# JWT
# IMPORTANT: Generate a strong secret for production (e.g. `openssl rand -hex 32`)
JWT_SECRET=change-me-to-a-strong-random-secret

# Node environment
NODE_ENV=development

# WebSocket server URL (used by the frontend to connect to Socket.IO)
NEXT_PUBLIC_WS_URL=http://localhost:3001

# WebRTC / MediaSoup
# The public IP that WebRTC clients will connect to (for NAT traversal)
# In development, use 127.0.0.1. In production, use your server's public IP.
ANNOUNCED_IP=127.0.0.1
