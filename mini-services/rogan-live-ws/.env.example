# ── Rogan Live · WebSocket Server Environment ─────────────────────────
# Copy this file to .env and fill in the values.
# NEVER commit your real .env file to version control.

# JWT Secret (must match the main app's JWT_SECRET)
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-strong-random-secret

# WebSocket server port (must match NEXT_PUBLIC_WS_URL in main app)
PORT=3001

# Allowed CORS origins (comma-separated)
WS_ORIGINS=http://localhost:3000
