generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String   @unique
  passwordHash String?
  googleId     String?  @unique
  displayName  String?
  avatar       String?
  bio          String?
  role         String   @default("user") // user | creator | admin
  isLive       Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  wallet       Wallet?
  ledgerAccount LedgerAccount?
  sentGifts    Gift[]
  receivedGifts Gift[]  @relation("ReceivedGifts")
  streams      Stream[]
  sentDMs      DirectMessage[] @relation("SentDMs")
  receivedDMs  DirectMessage[] @relation("ReceivedDMs")
  notifications Notification[]
  sentTransactions Transaction[] @relation("SentTransactions")
  receivedTransactions Transaction[] @relation("ReceivedTransactions")
  followers    Follow[] @relation("Followers")
  following    Follow[] @relation("Following")
  subscriptions Subscription[] @relation("Subscriber")
  subscribers  Subscription[] @relation("CreatorSubscriptions")
  serviceListings  ServiceListing[]
  buyerRequests    ServiceRequest[] @relation("BuyerRequests")
  creatorRequests  ServiceRequest[] @relation("CreatorRequests")
  pkBattles1     PKBattle[] @relation("PKCreator1")
  pkBattles2     PKBattle[] @relation("PKCreator2")
  pkWins         PKBattle[] @relation("PKWinner")
  writtenReviews ServiceReview[] @relation("WrittenReviews")
  receivedReviews ServiceReview[] @relation("ReceivedReviews")
  subscriptionTiers SubscriptionTier[]
}

model Wallet {
  id            String   @id @default(cuid())
  userId        String   @unique
  walletAddress String?  @unique
  linkedAt      DateTime?
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LedgerAccount {
  id        String @id @default(cuid())
  userId    String @unique
  tkBalance Int    @default(0) // TK in smallest unit (1 TK = 100 units)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Transaction {
  id          String   @id @default(cuid())
  type        String   // deposit | withdraw | gift_send | gift_receive | dm_payment | subscription | service_purchase | service_payout | service_refund
  amount      Int      // amount in TK units
  fromUserId  String?
  toUserId    String?
  referenceId String?  // gift_id, dm_id, etc.
  metadata    String?  // JSON string for extra data
  createdAt   DateTime @default(now())

  fromUser User? @relation("SentTransactions", fields: [fromUserId], references: [id], onDelete: SetNull)
  toUser   User? @relation("ReceivedTransactions", fields: [toUserId], references: [id], onDelete: SetNull)

  @@index([fromUserId])
  @@index([toUserId])
  @@index([createdAt])
  @@index([type])
}

model Stream {
  id          String   @id @default(cuid())
  creatorId   String
  title       String
  description String?
  streamKey   String   @unique
  isLive      Boolean  @default(false)
  isPrivate   Boolean  @default(false)
  thumbnailUrl String?
  viewerCount Int      @default(0)
  peakViewers Int      @default(0)
  startedAt   DateTime?
  endedAt     DateTime?
  createdAt   DateTime @default(now())

  creator User @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  chats   ChatMessage[]
  gifts   Gift[]
  accessList  StreamAccess[]
  pkBattle PKBattle?

  @@index([creatorId])
  @@index([isLive])
}

model ChatMessage {
  id        String   @id @default(cuid())
  streamId  String
  userId    String
  message   String
  type      String   @default("chat") // chat | system | gift_alert
  createdAt DateTime @default(now())

  stream Stream @relation(fields: [streamId], references: [id], onDelete: Cascade)

  @@index([streamId])
  @@index([createdAt])
}

model Gift {
  id         String   @id @default(cuid())
  streamId   String
  senderId   String?
  receiverId String?
  giftType   String   // rose | diamond | crown | fire | heart
  amount     Int      // TK amount
  message    String?
  createdAt  DateTime @default(now())

  sender   User?   @relation(fields: [senderId], references: [id], onDelete: SetNull)
  receiver User?   @relation("ReceivedGifts", fields: [receiverId], references: [id], onDelete: SetNull)
  stream   Stream @relation(fields: [streamId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
  @@index([streamId])
  @@index([createdAt])
}

model DirectMessage {
  id          String   @id @default(cuid())
  senderId    String
  receiverId  String
  message     String
  isPaid      Boolean  @default(false)
  price       Int      @default(0) // TK price for paid messages
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  sender   User @relation("SentDMs", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedDMs", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // gift_received | dm_received | stream_live | withdrawal_status | subscription_event
  title     String
  message   String
  isRead    Boolean  @default(false)
  metadata  String?  // JSON
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

model Follow {
  id         String   @id @default(cuid())
  followerId String
  followingId String
  createdAt  DateTime @default(now())

  follower  User @relation("Followers", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId])
}

model Subscription {
  id         String   @id @default(cuid())
  subscriberId String
  creatorId  String
  tier       String   @default("basic") // basic | premium | vip
  price      Int      @default(0) // TK per month
  isActive   Boolean  @default(true)
  startDate  DateTime @default(now())
  endDate    DateTime?

  subscriber User @relation("Subscriber", fields: [subscriberId], references: [id], onDelete: Cascade)
  creator    User @relation("CreatorSubscriptions", fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([subscriberId, creatorId])
  @@index([creatorId])
  @@index([subscriberId])
  @@index([isActive])
}

model ServiceListing {
  id          String   @id @default(cuid())
  creatorId   String
  title       String
  description String
  category    String   // video_call | custom_video | shoutout | coaching | other
  price       Int      // price in TK units (100 = 1 TK)
  deliveryDays Int     @default(3)
  isActive    Boolean  @default(true)
  rating      Float    @default(0)
  reviewCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator   User    @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  requests  ServiceRequest[]
  reviews ServiceReview[]

  @@index([creatorId])
  @@index([category])
  @@index([isActive])
}

model ServiceRequest {
  id          String   @id @default(cuid())
  serviceId   String
  buyerId     String
  creatorId   String
  message     String
  status      String   @default("pending") // pending | accepted | in_progress | delivered | completed | cancelled
  price       Int      // TK amount charged
  deliveryMessage String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  service ServiceListing @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  buyer   User @relation("BuyerRequests", fields: [buyerId], references: [id], onDelete: Cascade)
  creator User @relation("CreatorRequests", fields: [creatorId], references: [id], onDelete: Cascade)
  review ServiceReview[]

  @@index([buyerId])
  @@index([creatorId])
  @@index([serviceId])
  @@index([status])
}

model StreamAccess {
  id        String   @id @default(cuid())
  streamId  String
  userId    String
  grantedAt DateTime @default(now())

  stream Stream @relation(fields: [streamId], references: [id], onDelete: Cascade)

  @@unique([streamId, userId])
  @@index([userId])
}

model PKBattle {
  id            String   @id @default(cuid())
  streamId      String   @unique
  creator1Id    String
  creator2Id    String
  creator1Score Int      @default(0)
  creator2Score Int      @default(0)
  status        String   @default("pending") // pending | active | completed | cancelled
  duration      Int      @default(300) // seconds
  startedAt     DateTime?
  endedAt       DateTime?
  winnerId      String?
  createdAt     DateTime @default(now())

  stream   Stream @relation(fields: [streamId], references: [id], onDelete: Cascade)
  creator1 User   @relation("PKCreator1", fields: [creator1Id], references: [id], onDelete: Cascade)
  creator2 User   @relation("PKCreator2", fields: [creator2Id], references: [id], onDelete: Cascade)
  winner   User?  @relation("PKWinner", fields: [winnerId], references: [id])

  @@index([status])
  @@index([creator1Id])
  @@index([creator2Id])
}

model ServiceReview {
  id          String   @id @default(cuid())
  serviceId   String
  requestId   String
  reviewerId  String
  creatorId   String
  rating      Int      // 1-5
  comment     String?
  createdAt   DateTime @default(now())

  service ServiceListing @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  request ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  reviewer User @relation("WrittenReviews", fields: [reviewerId], references: [id], onDelete: Cascade)
  creator User @relation("ReceivedReviews", fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([requestId])
  @@index([serviceId])
  @@index([creatorId])
}

model SubscriptionTier {
  id          String   @id @default(cuid())
  creatorId   String
  name        String   // e.g. "Basic Fan", "Premium Supporter", "VIP Inner Circle"
  tier        String   // basic | premium | vip
  price       Int      // TK per month
  benefits    String   // JSON array of benefit strings
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  creator User @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([creatorId])
  @@index([tier])
}
